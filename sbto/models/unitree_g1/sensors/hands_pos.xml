<mujoco>
    <sensor>
        <!-- hands position and quat -->
        <framepos objtype="site" objname="right_palm" name="right_hand_pos"/>
        <framepos objtype="site" objname="left_palm" name="left_hand_pos"/>
        <framequat name="left_hand_orientation" objtype="site" objname="left_palm"/>
        <framequat name="right_hand_orientation" objtype="site" objname="right_palm"/>
        <!-- hands position and quat in obj ref frame -->
        <framepos name="right_hand_pos_obj_frame" objtype="site" objname="right_palm" reftype="geom" refname="obj"/>
        <framepos name="left_hand_pos_obj_frame" objtype="site" objname="left_palm"  reftype="geom" refname="obj"/>
        <framequat name="left_hand_orientation_obj_frame" objtype="site" objname="left_palm" reftype="geom" refname="obj"/>
        <framequat name="right_hand_orientation_obj_frame" objtype="site" objname="right_palm" reftype="geom" refname="obj"/>
    </sensor>
</mujoco>